# Banco PostgreSQL (use o do seu sistema ou um schema dedicado)
DATABASE_URL=postgres://usuario:senha@localhost:5432/govsistem
PGSSL=false

# Porta usada só no modo standalone (src/index.js)
GOVAVALIA_PORT=4000

# Caminho da tela pública -> www.govsistem.com.br/avalia
GOVAVALIA_BASE_PATH=/avalia

# Domínio do painel -> avalia.govsistem.com.br
GOVAVALIA_ADMIN_DOMAIN=avalia.govsistem.com.br

# CORS (separado por vírgula)
GOVAVALIA_ALLOWED_ORIGINS=https://www.govsistem.com.br,https://avalia.govsistem.com.br

# Nomes dos perfis do SEU sistema que acessam o painel
GOVAVALIA_ROLE_GESTOR=gestor
GOVAVALIA_ROLE_OUVIDORIA=ouvidoria

# Retenção do contato das manifestações identificadas (dias)
GOVAVALIA_RETENCAO_CONTATO_DIAS=365

# APENAS DEV: injeta um usuário fake para testar o painel sem login.
# NUNCA use 'true' em produção.
GOVAVALIA_DEV_FAKE_USER=false
