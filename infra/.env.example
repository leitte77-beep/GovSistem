# PostgreSQL
POSTGRES_DB=doe
POSTGRES_USER=doe_user
POSTGRES_PASSWORD=CHANGE_ME

# MinIO
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=doe-publicacoes

# API
API_CORS_ORIGINS=http://localhost:7201,http://localhost:7200
API_DEBUG=true
API_SECRET_KEY=CHANGE_ME

# Signer
SIGNER_PROVIDER=a1
SIGNER_A1_PFX_PATH=/certs/cert.pfx
SIGNER_A1_PASSWORD=
SIGNER_CERTS_DIR=./certs

# Worker
WORKER_CONCURRENCY=4

# Internal service auth (worker -> API)
INTERNAL_API_KEY=CHANGE_ME

# ChatGov (WhatsApp Attendant Module)
CHATGOV_JWT_SECRET=CHANGE_ME_STRONG_SECRET
CHATGOV_STORAGE_DRIVER=local
CHATGOV_SOCKET_CORS_ORIGIN=http://localhost:7201
CHATGOV_CREDS_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_KEY_FOR_ENCRYPTION
CHATGOV_RATE_LIMIT_PER_MINUTE=30
