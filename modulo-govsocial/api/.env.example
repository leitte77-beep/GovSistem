# ── GovSocial API (Módulo de Assistência Social / SUAS) ──
APP_NAME=GovSocial API
DEBUG=true
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Banco (PostgreSQL 16) ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=govsocial
POSTGRES_USER=govsocial_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis / Celery ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── MinIO (S3) ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=govsocial-files
MINIO_SECURE=false

# ── Segurança / JWT ──
SECRET_KEY=CHANGE_ME
# SSO: DEVE ser igual ao SECRET_KEY da plataforma SaaS (assina o token module_access).
SAAS_JWT_SECRET=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# SSO: DEVE ser igual ao INTERNAL_API_KEY da plataforma (protege /internal/sync-*).
INTERNAL_API_KEY=

# ── Criptografia de campos sensíveis (LGPD art. 11) ──
# Chave Fernet (urlsafe base64, 44 chars). Se vazio, é derivada de SECRET_KEY (apenas dev).
FIELD_ENCRYPTION_KEY=

# ── CORS ──
CORS_ORIGINS=http://localhost:7400,http://localhost:7401
PUBLIC_URL=http://localhost:7400
