# Build de produção STANDALONE (subdomínio próprio govsocial.govsistem.com.br).
# Servido na raiz "/", consumindo a API real, sem mock.

# Prefixo de rota na raiz do subdomínio.
VITE_BASE_PATH=/

# API real do módulo (mesmo host; o nginx roteia /api/govsocial para a API).
VITE_API_URL=/api/govsocial/v1

# Mock DESLIGADO em produção.
VITE_API_MOCK=

# Retorno no logout (plataforma SaaS).
VITE_PLATFORM_URL=https://admin.govsistem.com.br/
