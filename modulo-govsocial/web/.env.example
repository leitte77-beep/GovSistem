# URL base da aplicação no path do servidor
VITE_BASE_PATH=/

# Origem da API real do módulo (usada quando VITE_API_MOCK != 1).
# Em dev, o Vite faz proxy de /api para http://localhost:8000.
VITE_API_URL=/api/govsocial/v1

# Liga o mock server (MSW). 1 = mock; vazio/0 = API real.
VITE_API_MOCK=1

# Perfil simulado no modo mock (troca as claims do JWT falso).
# Valores: gestor_municipal | coordenador_unidade | tecnico_superior |
#          tecnico_medio | recepcao | vigilancia | conselho | ADMIN
VITE_MOCK_ROLE=tecnico_superior

# URL da plataforma GovSistem (usada para redirecionamento de logout)
VITE_PLATFORM_URL=https://admin.govsistem.com.br/
