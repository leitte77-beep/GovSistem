# ===========================================
# Módulo Diário — Environment Configuration
# ===========================================
# Copy this file to .env and fill in values.
# Never commit .env to version control.

# --- App ---
APP_NAME="Modulo Diario API"
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS='["http://localhost:9202","http://localhost:9200"]'
PUBLIC_URL=http://localhost:9200

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=modulo_diario
POSTGRES_USER=diario_user
POSTGRES_PASSWORD=change-me-in-dev

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- MinIO / Object Storage ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=change-me-in-dev
MINIO_SECRET_KEY=change-me-in-dev
MINIO_BUCKET=doe-publicacoes
MINIO_SECURE=false
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change-me-in-dev

# --- Security ---
SECRET_KEY=change-me-in-dev
INTERNAL_API_KEY=change-me-in-dev
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- SSO / SaaS Platform Integration ---
# SAAS_JWT_SECRET: chave compartilhada com a plataforma SaaS para validar
#   tokens module_access (SSO). Deve ser IGUAL ao SECRET_KEY do SaaS.
SAAS_JWT_SECRET=
# SAAS_INTERNAL_API_KEY: chave alternativa para autenticar chamadas
#   /internal/sync-* vindas da plataforma SaaS.
SAAS_INTERNAL_API_KEY=

# --- Signer ---
SIGNER_URL=http://signer:8100
SIGNER_PROVIDER=a1
SIGNER_A1_PFX_PATH=/certs/cert.pfx
SIGNER_A1_PASSWORD=
VERIFICATION_BASE_URL=https://govsistem.com.br/verificar

# --- API / Worker ---
API_URL=http://api:8000
WORKER_CONCURRENCY=4

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=uploads
STORAGE_TENANT_ISOLATION=true

# --- Frontend URLs ---
NEXT_PUBLIC_API_URL=http://localhost:9201/api/v1
NEXT_PUBLIC_ADMIN_URL=http://localhost:9202

# --- Observability (optional) ---
SENTRY_DSN=

# --- Antivirus (optional) ---
CLAMAV_HOST=
CLAMAV_PORT=3310
