# PostgreSQL
POSTGRES_DB=doe
POSTGRES_USER=doe_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# MinIO
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=doe-publicacoes
MINIO_SECURE=false

# API
API_PORT=8000
API_CORS_ORIGINS=http://localhost:7201,http://localhost:7200
API_LOG_LEVEL=DEBUG
API_SECRET_KEY=CHANGE_ME

# Signer
SIGNER_PORT=8100
SIGNER_LOG_LEVEL=DEBUG
SIGNER_PROVIDER=a1
SIGNER_A1_PFX_PATH=/certs/cert.pfx
SIGNER_A1_PASSWORD=

# Worker
WORKER_LOG_LEVEL=DEBUG
WORKER_CONCURRENCY=4

# Internal service auth (worker -> API)
INTERNAL_API_KEY=CHANGE_ME

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ADMIN_URL=http://localhost:7201

# Staging (sobrescreve as vars acima para o ambiente de staging)
STG_POSTGRES_PASSWORD=staging_password
STG_SECRET_KEY=staging-secret-key-change-me
STG_INTERNAL_API_KEY=staging-internal-key-123
